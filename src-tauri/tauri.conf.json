{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "JustNotes",
  "version": "0.1.0",
  "identifier": "com.kreativekorna.justnotes",
  "build": {
    "frontendDist": "../apps/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @justnotes/web dev",
    "beforeBuildCommand": "pnpm --filter @justnotes/web build"
  },
  "app": {
    "windows": [
      {
        "title": "JustNotes",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "backgroundColor": "#0a0d12"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/REPLACE_ME_ORG/justnotes/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_ME_RUN_tauri_signer_generate"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["justnotes"]
      }
    }
  }
}
