{
  "name": "justnotes-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @justnotes/web dev",
    "dev:api": "pnpm --filter @justnotes/api dev",
    "dev:marketing": "pnpm --filter @justnotes/marketing dev",
    "build": "pnpm -r --parallel build",
    "lint": "pnpm -r --parallel lint",
    "tauri": "tauri",
    "tauri:dev": "cross-env WEBKIT_DISABLE_DMABUF_RENDERER=1 WEBKIT_DISABLE_COMPOSITING_MODE=1 WEBKIT_FORCE_SANDBOX=0 LIBGL_ALWAYS_SOFTWARE=1 tauri dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "cross-env": "^10.1.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "vite": "^6.0.0",
      "kysely": "^0.28.17",
      "drizzle-orm": "^0.45.2",
      "drizzle-orm@<0.45.0": "^0.45.2"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp",
      "@tauri-apps/cli"
    ]
  }
}
